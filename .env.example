# Firebase (from Firebase Console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="salon-hasi.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="salon-hasi"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="salon-hasi.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# Firebase Admin (required for Firestore, login, admin, seed) — pick ONE option:
#
# Option A — paste full JSON on one line:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"salon-hasi",...}'
#
# Option B — save the key file in project root (gitignored) and set:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
#
# Vercel deploy — add in Project Settings → Environment Variables (Production + Preview):
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"salon-hasi",...}'
# The build auto-fetches NEXT_PUBLIC_FIREBASE_* from that JSON.
# Or run locally: npm run setup:firebase-web:vercel  and paste all printed values into Vercel.

# Google Drive — salon portfolio uploads (optional)
GOOGLE_DRIVE_FOLDER_ID="1Fc6NwiEljsTh5A6uS5NZ6mRH_WsZdTjO"
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
